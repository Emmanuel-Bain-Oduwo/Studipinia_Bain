# ============================================
# STUDIPINIA — Environment Variables Template
# Copy to .env and fill in real values
# ============================================

# Database
DB_PASSWORD=your_secure_password_here

# Backend Security
SECRET_KEY=your_random_secret_key_at_least_32_chars

# Environment
ENVIRONMENT=production

# Frontend
NEXT_PUBLIC_API_URL=https://api.studipinia.com

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=https://studipinia.com,https://www.studipinia.com

# Cloudinary (for file/image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend (for transactional emails)
RESEND_API_KEY=re_xxxxxxxxxxxx

# AI Services (optional — for future AI features)
OPENAI_API_KEY=sk-xxxxxxxx
DEEPSEEK_API_KEY=xxxxxxxx
